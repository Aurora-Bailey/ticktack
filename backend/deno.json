{
  "lock": false,
  "tasks": {
    "dev": "deno run --reload -A src/main.ts",
    "test": "deno test --allow-env --allow-read --allow-net",
    "seed": "deno run -A src/scripts/seed.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "importMap": "./import_map.json"
}
